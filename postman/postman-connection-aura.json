{
  "info": {
    "_postman_id": "d8a2ff00-4cf2-457d-b10f-bde30140c1e2",
    "name": "Aura_API",
    "description": "Tested Postman collection for managing Neo4j Aura instances via the Aura REST API.\n\nBefore running any request, create a Postman environment with the following variables:\n  - aura_token     (auto-populated by Get_Token)\n  - instance_id    (auto-populated by Create_Instance, or set manually)\n\nStart by running Get_Token — it will store the Bearer token automatically for all subsequent requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Get_Token",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "let responseData = pm.response.json();",
              "let myToken = responseData.access_token;",
              "pm.environment.set(\"aura_token\", myToken);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "auth": {
          "type": "basic",
          "basic": [
            {
              "key": "username",
              "value": "Your_Aura_API_Client_Id",
              "type": "string"
            },
            {
              "key": "password",
              "value": "Your_Aura_API_Client_Secret",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/x-www-form-urlencoded",
            "type": "text"
          }
        ],
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            {
              "key": "grant_type",
              "value": "client_credentials",
              "type": "text"
            }
          ]
        },
        "url": {
          "raw": "https://api.neo4j.io/oauth/token",
          "protocol": "https",
          "host": ["api", "neo4j", "io"],
          "path": ["oauth", "token"]
        }
      },
      "response": []
    },
    {
      "name": "Create_Instance",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "let responseData = pm.response.json();",
              "let myInstanceId = responseData.data.id;",
              "pm.environment.set(\"instance_id\", myInstanceId);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{aura_token}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"name\": \"your-instance-name\",\n    \"type\": \"business-critical\",\n    \"region\": \"us-east1\",\n    \"cloud_provider\": \"gcp\",\n    \"tenant_id\": \"your-tenant-id\",\n    \"memory\": \"8G\",\n    \"storage\": \"16G\",\n    \"graph_analytics_plugin\": false,\n    \"vector_optimized\": false\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "https://api.neo4j.io/v1/instances",
          "protocol": "https",
          "host": ["api", "neo4j", "io"],
          "path": ["v1", "instances"]
        }
      },
      "response": []
    },
    {
      "name": "Get_Instance_State",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [""],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{aura_token}}",
              "type": "string"
            }
          ]
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "https://api.neo4j.io/v1/instances/{{instance_id}}",
          "protocol": "https",
          "host": ["api", "neo4j", "io"],
          "path": ["v1", "instances", "{{instance_id}}"]
        }
      },
      "response": []
    },
    {
      "name": "Pause_Instance",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [""],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{aura_token}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [
          {
            "key": "Accept",
            "value": "application/json",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": {
          "raw": "https://api.neo4j.io/v1/instances/{{instance_id}}/pause",
          "protocol": "https",
          "host": ["api", "neo4j", "io"],
          "path": ["v1", "instances", "{{instance_id}}", "pause"]
        }
      },
      "response": []
    },
    {
