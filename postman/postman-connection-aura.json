            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": {
          "raw": "https://api.neo4j.io/v1/instances/{{instance_id}}/resume",
          "protocol": "https",
          "host": ["api", "neo4j", "io"],
          "path": ["v1", "instances", "{{instance_id}}", "resume"]
        }
      },
      "response": []
    },
    {
      "name": "Delete_Instance",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{aura_token}}",
              "type": "string"
            }
          ]
        },
        "method": "DELETE",
        "header": [
          {
            "key": "Accept",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": {
          "raw": "https://api.neo4j.io/v1/instances/{{instance_id}}",
          "protocol": "https",
          "host": ["api", "neo4j", "io"],
          "path": ["v1", "instances", "{{instance_id}}"]
        }
      },
      "response": []
    }
  ]
}
